# ============================================
# Daily Job Hunter Agent - Environment Config
# ============================================

# === EMAIL CONFIG (Gmail) ===
# To use Gmail, you need an "App Password" (not your regular password).
# Steps:
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Select "Mail" and your device
#   3. Generate and copy the 16-char password
#   4. Paste it below
EMAIL_USER=shuklavishwagaurav@gmail.com
EMAIL_PASS=your_gmail_app_password_here
EMAIL_TO=shuklavishwagaurav@gmail.com

# === JSEARCH API CONFIG (RapidAPI) ===
# Get a free API key (200 requests/month free, no card required)
# 1. Sign up at https://rapidapi.com
# 2. Go to https://rapidapi.com/letscrape-65710003/api/jsearch
# 3. Subscribe to the free "Basic" plan
# 4. Copy your Application Key ("X-RapidAPI-Key") from the dashboard
RAPIDAPI_KEY=your_rapidapi_key_here

# === GEMINI ATS CONFIG (Google AI Studio) ===
# Get a free API key (No credit card required, completely free)
# 1. Go to https://aistudio.google.com/
# 2. Click "Get API Key"
# 3. Copy the key and paste below
GEMINI_API_KEY=your_gemini_api_key_here

# === JOB SEARCH CONFIG ===
# Comma-separated target cities
TARGET_CITIES=Hyderabad,Bangalore,Pune

# Comma-separated target roles
TARGET_ROLES=Frontend Developer,React Developer,Software Engineer,Full-Stack Developer,UI Engineer

# Comma-separated core skills
CORE_SKILLS=React,Redux,JavaScript,NodeJS,HTML5,CSS3,REST APIs

# Salary range (in LPA)
MIN_SALARY_LPA=10
MAX_SALARY_LPA=20

# Experience (years)
EXPERIENCE_YEARS=2

# === SCHEDULE CONFIG ===
# Cron expression (default: 9:00 AM every day)
CRON_SCHEDULE=0 9 * * *

# Timezone
TZ=Asia/Kolkata
