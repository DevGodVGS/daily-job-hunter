/**
 * Generate search queries based on config.
 * @param {object} config - Search configuration from .env
 * @returns {string[]} Array of search query strings
 */
export function generateSearchQueries(config) {
  const { targetCities, targetRoles, coreSkills, experienceYears } = config;
  const queries = [];

  // Primary queries: role + city + experience
  for (const role of targetRoles) {
    for (const city of targetCities) {
      queries.push(
        `${role} ${city} India ${experienceYears}+ years experience 2026 hiring`
      );
    }
  }

  // Skill-specific queries
  for (const city of targetCities) {
    queries.push(
      `React Redux frontend developer ${city} startup product company hiring ${new Date().getFullYear()}`
    );
  }

  return queries;
}

/**
 * Filter companies based on target cities.
 * @param {string[]} targetCities
 * @returns {object[]} Matching companies
 */
export function filterCompaniesByCities(targetCities) {
  return TARGET_COMPANIES.filter((company) =>
    company.locations.some((loc) =>
      targetCities.some(
        (city) => loc.toLowerCase().includes(city.toLowerCase())
      )
    )
  );
}

/**
 * Build the HTML for a single company card in the email.
 * @param {object} company
 * @param {number} index
 * @returns {string} HTML string
 */
export function buildCompanyCard(company, index) {
  const locationBadges = company.locations
    .map(
      (loc) =>
        `<span style="display:inline-block;background:#e8f5e9;color:#2e7d32;padding:2px 8px;border-radius:12px;font-size:12px;margin-right:4px;">${loc}</span>`
    )
    .join('');

  const categoryColor = {
    Fintech: '#ff6f00',
    'Developer Tools': '#1565c0',
    SaaS: '#6a1b9a',
    'E-Commerce': '#c62828',
    'Consumer Tech': '#00838f',
    MarTech: '#4527a0',
    'Cloud/Data': '#0277bd',
    'Enterprise SaaS': '#283593',
  };

  return `
    <div style="background:#fff;border:1px solid #e0e0e0;border-radius:12px;padding:20px;margin-bottom:16px;box-shadow:0 2px 8px rgba(0,0,0,0.06);">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
        <h3 style="margin:0;color:#1a1a1a;font-size:18px;">
          ${index}. ${company.name}
          <span style="display:inline-block;background:${categoryColor[company.category] || '#424242'};color:#fff;padding:2px 8px;border-radius:12px;font-size:11px;margin-left:8px;vertical-align:middle;">${company.category}</span>
        </h3>
        <span style="color:#2e7d32;font-weight:600;font-size:14px;">${company.salaryRange}</span>
      </div>
      <p style="margin:4px 0 12px;color:#666;font-size:13px;">${company.description}</p>
      <div style="margin-bottom:12px;">
        ${locationBadges}
        <span style="display:inline-block;background:#e3f2fd;color:#1565c0;padding:2px 8px;border-radius:12px;font-size:12px;margin-left:4px;">
          ${company.interviewRounds} rounds
        </span>
      </div>
      <div style="display:flex;gap:8px;">
        <a href="${company.careersUrl}" style="display:inline-block;background:#1a73e8;color:#fff;padding:8px 16px;border-radius:8px;text-decoration:none;font-size:13px;font-weight:500;">🔗 Careers Page</a>
        <a href="${company.linkedinUrl}" style="display:inline-block;background:#0a66c2;color:#fff;padding:8px 16px;border-radius:8px;text-decoration:none;font-size:13px;font-weight:500;">💼 LinkedIn Jobs</a>
      </div>
    </div>
  `;
}
